+          ? 'Tienes acceso completo. Ya puedes iniciar sesi├│n.'
           : 'Cuenta b├ísica creada. Usa un c├│digo para acceso premium.'
       })
       setAuthMode('login')
@@ -259,6 +282,63 @@ export default function App() {
     )
   }
 
