# =============================================================
# NL VIP CLUB — Variables de entorno requeridas
# Copia este archivo como .env.local y rellena los valores
# =============================================================

# ---------------------------
# Supabase (OBLIGATORIO)
# ---------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Solo para uso en servidor (API routes). NUNCA usar NEXT_PUBLIC_ para esta clave.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------
# OpenAI (OBLIGATORIO para IA)
# ---------------------------
OPENAI_API_KEY=sk-...

# ---------------------------
# Web Push / Notificaciones
# ---------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:admin@tudominio.com

# ---------------------------
# Spoonacular (recetas)
# ---------------------------
SPOONACULAR_API_KEY=your-spoonacular-key

# ---------------------------
# Unsplash (imágenes de recetas)
# ---------------------------
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# ---------------------------
# MongoDB (ruta catch-all /api/[[...path]])
# ---------------------------
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net
DB_NAME=your-database-name

# ---------------------------
# Stitch SDK (opcional)
# ---------------------------
STITCH_API_KEY=your-stitch-key

# ---------------------------
# URL base del sitio
# ---------------------------
NEXT_PUBLIC_BASE_URL=https://tudominio.com
NEXT_PUBLIC_SITE_URL=https://tudominio.com

# ---------------------------
# CORS (opcional, por defecto "*" — configura en producción)
# ---------------------------
CORS_ORIGINS=https://tudominio.com,https://app.tudominio.com

# ---------------------------
# Sentry (monitorización de errores en producción)
# Obtén el DSN en: sentry.io → tu proyecto → Settings → Client Keys
# ---------------------------
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
SENTRY_ORG=tu-organizacion
SENTRY_PROJECT=nl-vip-club
